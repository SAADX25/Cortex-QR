<Application x:Class="CortexQR.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:CortexQR"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Material Design Core -->
                <materialDesign:BundledTheme BaseTheme="Dark"
                                             PrimaryColor="Blue"
                                             SecondaryColor="LightBlue" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign2.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <SolidColorBrush x:Key="PrimaryHueMidBrush" Color="#007ACC" />
            <SolidColorBrush x:Key="PrimaryHueLightBrush" Color="#03A9F4" />

            <!-- Custom App Resources -->
            <Style x:Key="CardStyle" TargetType="materialDesign:Card">
                <Setter Property="Background" Value="#1E1E1E"/>
                <Setter Property="BorderBrush" Value="#2D2D2D"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Margin" Value="0,0,0,16"/>
                <Setter Property="Padding" Value="20,16"/>
                <Setter Property="UniformCornerRadius" Value="12"/>
            </Style>

            <!-- Color Swatch Button -->
            <Style x:Key="ColorSwatchButton" TargetType="Button">
                <Setter Property="Width" Value="32"/>
                <Setter Property="Height" Value="32"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Ellipse x:Name="SwatchEllipse"
                                         Width="32" Height="32"
                                         Fill="{TemplateBinding Background}"
                                         StrokeThickness="2"
                                         Stroke="#20000000"/>
                                <Ellipse x:Name="HoverOverlay"
                                         Width="32" Height="32"
                                         Fill="Transparent"
                                         Opacity="0"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="HoverOverlay" Property="Fill" Value="#30000000"/>
                                    <Setter TargetName="HoverOverlay" Property="Opacity" Value="1"/>
                                    <Setter TargetName="SwatchEllipse" Property="StrokeThickness" Value="3"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="SwatchEllipse" Property="Width" Value="28"/>
                                    <Setter TargetName="SwatchEllipse" Property="Height" Value="28"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
