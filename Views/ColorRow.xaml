<UserControl x:Class="CortexQR.Views.ColorRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:CortexQR.Views"
             x:Name="Root">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="110"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Label -->
        <TextBlock Grid.Column="0"
                   Text="{Binding Label, ElementName=Root}"
                   VerticalAlignment="Center"
                   FontSize="12"
                   Foreground="{DynamicResource MaterialDesignBodyLight}"/>

        <!-- Hex TextBox -->
        <TextBox x:Name="HexBox"
                 Grid.Column="1"
                 materialDesign:HintAssist.Hint="#RRGGBB"
                 materialDesign:HintAssist.IsFloating="False"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 FontFamily="Consolas"
                 FontSize="13"
                 Padding="8,6"
                 VerticalContentAlignment="Center"
                 KeyDown="HexBox_KeyDown"
                 LostFocus="HexBox_LostFocus"/>

        <!-- Color Swatch Button -->
        <Grid Grid.Column="2" Margin="10,0,0,0">
            <Button x:Name="SwatchBtn"
                    Style="{StaticResource ColorSwatchButton}"
                    Background="{Binding SelectedBrush, ElementName=Root}"
                    Click="SwatchBtn_Click"
                    Cursor="Hand"/>
        </Grid>
    </Grid>
</UserControl>
