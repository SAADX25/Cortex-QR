<UserControl x:Class="CortexQR.Views.ColorPickerPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Width="290">
    <UserControl.Resources>
        <Style x:Key="SlimSliderThumb" TargetType="Thumb">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Ellipse Fill="#E0EEFF" Stroke="#2A3A5C" StrokeThickness="1.5"
                                 Width="18" Height="18"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SlimSlider" TargetType="Slider">
            <Setter Property="Height" Value="20"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Opacity="0" Command="Slider.DecreaseLarge"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SlimSliderThumb}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Opacity="0" Command="Slider.IncreaseLarge"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="#0F1520" CornerRadius="12"
            BorderBrush="#1E3050" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#0A84FF" BlurRadius="40" ShadowDepth="0" Opacity="0.22"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="1"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── Title Bar (drag handle) ───────────────────────────── -->
            <Border Grid.Row="0" CornerRadius="12,12,0,0"
                    Cursor="SizeAll"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Border.Background>
                    <SolidColorBrush Color="#0A1020"/>
                </Border.Background>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2"/>
                        <RowDefinition Height="36"/>
                    </Grid.RowDefinitions>

                    <!-- Top gradient accent line -->
                    <Border Grid.Row="0" CornerRadius="12,12,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#0A84FF" Offset="0.35"/>
                                <GradientStop Color="#06B6D4" Offset="0.65"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="#2563EB" BlurRadius="10" ShadowDepth="0" Opacity="0.8"/>
                        </Border.Effect>
                    </Border>

                    <!-- Title row -->
                    <Grid Grid.Row="1" Margin="14,0,14,0">
                        <!-- Left: icon + label -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="18" Height="18" CornerRadius="5" Margin="0,0,8,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#0A84FF" Offset="0"/>
                                        <GradientStop Color="#06B6D4" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <materialDesign:PackIcon Kind="Palette"
                                                         Width="10" Height="10"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"
                                                         Foreground="White"/>
                            </Border>
                            <TextBlock Text="COLOR PICKER"
                                       FontSize="9" FontWeight="Bold"
                                       Foreground="#5A7AA8"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Right: drag-hint dots -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <Ellipse Width="3" Height="3" Fill="#1E3050" Margin="1,0"/>
                            <Ellipse Width="3" Height="3" Fill="#1E3050" Margin="1,0"/>
                            <Ellipse Width="3" Height="3" Fill="#1E3050" Margin="1,0"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- Divider -->
            <Border Grid.Row="1" Background="#1E3050"/>

            <!-- ── Main Content ─────────────────────────────────────── -->
            <Grid Grid.Row="2" Margin="14,12,14,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="160"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- SV Canvas -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Rectangle x:Name="SvCanvas" RadiusX="6" RadiusY="6" Cursor="Cross"
                               MouseDown="SvCanvas_MouseDown"
                               MouseMove="SvCanvas_MouseMove"
                               MouseUp="SvCanvas_MouseUp">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="White" Offset="0"/>
                                <GradientStop x:Name="HueGradientStop" Color="Red" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <Rectangle RadiusX="6" RadiusY="6" IsHitTestVisible="False">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="Black" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <Canvas x:Name="SvCrosshairCanvas" IsHitTestVisible="False">
                        <Ellipse x:Name="SvCrosshair" Width="14" Height="14"
                                 Stroke="White" StrokeThickness="2"
                                 Fill="Transparent"
                                 Canvas.Left="0" Canvas.Top="0">
                            <Ellipse.Effect>
                                <DropShadowEffect ShadowDepth="1" BlurRadius="3" Opacity="0.7"/>
                            </Ellipse.Effect>
                        </Ellipse>
                    </Canvas>
                </Grid>

                <!-- Hue Slider -->
                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <Rectangle Height="16" RadiusX="8" RadiusY="8">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FF0000" Offset="0.000"/>
                                <GradientStop Color="#FFFF00" Offset="0.167"/>
                                <GradientStop Color="#00FF00" Offset="0.333"/>
                                <GradientStop Color="#00FFFF" Offset="0.500"/>
                                <GradientStop Color="#0000FF" Offset="0.667"/>
                                <GradientStop Color="#FF00FF" Offset="0.833"/>
                                <GradientStop Color="#FF0000" Offset="1.000"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <Slider x:Name="HueSlider" Minimum="0" Maximum="360"
                            Value="0" Background="Transparent"
                            Style="{StaticResource SlimSlider}"
                            ValueChanged="HueSlider_ValueChanged"/>
                </Grid>

                <!-- Alpha Slider -->
                <Grid Grid.Row="2" Margin="0,0,0,12">
                    <Rectangle Height="16" RadiusX="8" RadiusY="8">
                        <Rectangle.Fill>
                            <DrawingBrush TileMode="Tile" ViewportUnits="Absolute" Viewport="0,0,10,10">
                                <DrawingBrush.Drawing>
                                    <DrawingGroup>
                                        <GeometryDrawing Brush="#2A3A5C">
                                            <GeometryDrawing.Geometry>
                                                <RectangleGeometry Rect="0,0,10,10"/>
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                        <GeometryDrawing Brush="#151F30">
                                            <GeometryDrawing.Geometry>
                                                <GeometryGroup>
                                                    <RectangleGeometry Rect="0,0,5,5"/>
                                                    <RectangleGeometry Rect="5,5,5,5"/>
                                                </GeometryGroup>
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                    </DrawingGroup>
                                </DrawingBrush.Drawing>
                            </DrawingBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <Rectangle x:Name="AlphaGradientRect" Height="16" RadiusX="8" RadiusY="8" IsHitTestVisible="False"/>
                    <Slider x:Name="AlphaSlider" Minimum="0" Maximum="255"
                            Value="255" Background="Transparent"
                            Style="{StaticResource SlimSlider}"
                            ValueChanged="AlphaSlider_ValueChanged"/>
                </Grid>

                <!-- Hex Input + Color Preview -->
                <Grid Grid.Row="3" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="HexTextBox" Grid.Column="0"
                             FontSize="13" FontFamily="Consolas"
                             Padding="8,6" VerticalContentAlignment="Center"
                             MaxLength="9"
                             Background="#0A1020" Foreground="#7AAAD8"
                             CaretBrush="#7AAAD8" BorderBrush="#1E3050"
                             BorderThickness="1"
                             KeyDown="HexTextBox_KeyDown"
                             LostFocus="HexTextBox_LostFocus"/>
                    <Ellipse x:Name="PreviewEllipse" Grid.Column="1"
                             Width="32" Height="32" Margin="10,0,0,0"
                             Stroke="#1E3050" StrokeThickness="1"/>
                </Grid>

                <!-- APPLY / CANCEL Buttons -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="OkButton" Grid.Column="0" Content="APPLY"
                            Margin="0,0,5,0" Height="32"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="#0A84FF"
                            FontWeight="Bold" FontSize="11"
                            Click="OkButton_Click"/>
                    <Button x:Name="CancelButton" Grid.Column="1" Content="CANCEL"
                            Margin="5,0,0,0" Height="32"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="#3A5070" FontSize="11"
                            Click="CancelButton_Click"/>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>
