<Window x:Class="CortexQR.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:helpers="clr-namespace:CortexQR.Helpers"
        xmlns:local="clr-namespace:CortexQR.Views"
        Title="Cortex QR" Height="760" Width="1100"
        MinWidth="920" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize"
        Background="Transparent"
        TextElement.Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="{materialDesign:MaterialDesignFont}"
        FontSize="14">

    <!-- Root border — rounded window -->
    <Border Background="{StaticResource SurfaceBrush}"
            CornerRadius="14"
            ClipToBounds="True">

        <!-- Subtle outer glow -->
        <Border.Effect>
            <DropShadowEffect Color="#0A84FF" BlurRadius="40"
                              ShadowDepth="0" Opacity="0.15"/>
        </Border.Effect>

        <materialDesign:DialogHost Identifier="RootDialog"
                                   CloseOnClickAway="True"
                                   DialogMargin="24">
            <materialDesign:DialogHost.OverlayBackground>
                <SolidColorBrush Color="#CC000000"/>
            </materialDesign:DialogHost.OverlayBackground>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="54"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ══════════════════════════════════════════════════
                     ROW 0 — Custom Title Bar
                ══════════════════════════════════════════════════ -->
                <Border x:Name="HeaderBar"
                        Grid.Row="0"
                        Background="{StaticResource Surface1Brush}"
                        MouseLeftButtonDown="HeaderBar_MouseLeftButtonDown">

                    <!-- Bottom accent line -->
                    <Border.BorderThickness>0,0,0,1</Border.BorderThickness>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#1A1440"/>
                    </Border.BorderBrush>

                    <Grid Margin="18,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Logo + App Name -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Icon with gradient bg -->
                            <Border Width="32" Height="32" CornerRadius="9" Margin="0,0,11,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#0A84FF" Offset="0"/>
                                        <GradientStop Color="#06B6D4" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="#0A84FF" BlurRadius="12"
                                                      ShadowDepth="0" Opacity="0.6"/>
                                </Border.Effect>
                                <materialDesign:PackIcon Kind="QrCode"
                                                         Width="18" Height="18"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"
                                                         Foreground="White"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock FontSize="13"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
>
                                    <Run Text="CORTEX " Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <Run Foreground="{StaticResource AccentBrush}">QR</Run>
                                </TextBlock>
                                <TextBlock Text="Professional QR Studio"
                                           FontSize="10"
                                           Foreground="{StaticResource TextMutedBrush}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Window Chrome Buttons -->
                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button x:Name="MinimizeButton"
                                    Style="{StaticResource ChromeButtonStyle}"
                                    ToolTip="Minimize"
                                    Click="MinimizeButton_Click">
                                <materialDesign:PackIcon Kind="WindowMinimize" Width="15" Height="15"/>
                            </Button>
                            <Button x:Name="MaximizeButton"
                                    Style="{StaticResource ChromeButtonStyle}"
                                    ToolTip="Maximize"
                                    Margin="2,0,0,0"
                                    Click="MaximizeButton_Click">
                                <materialDesign:PackIcon Kind="WindowMaximize" Width="15" Height="15"/>
                            </Button>
                            <Button x:Name="CloseButton"
                                    Style="{StaticResource CloseButtonStyle}"
                                    ToolTip="Close"
                                    Margin="2,0,0,0"
                                    Click="CloseButton_Click">
                                <materialDesign:PackIcon Kind="Close" Width="15" Height="15"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ══════════════════════════════════════════════════
                     ROW 1 — Sidebar + Content
                ══════════════════════════════════════════════════ -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" MinWidth="150" MaxWidth="360"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ── SIDEBAR ──────────────────────────────── -->
                    <Border Grid.Column="0" Background="{StaticResource Surface1Brush}">
                        <DockPanel>

                            <!-- Bottom: version + status -->
                            <StackPanel DockPanel.Dock="Bottom" Margin="12,0,12,18">
                                <!-- Separator -->
                                <Border Height="1" Margin="4,0,4,14">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="Transparent" Offset="0"/>
                                            <GradientStop Color="#1A2D4A" Offset="0.5"/>
                                            <GradientStop Color="Transparent" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Ellipse Width="6" Height="6" VerticalAlignment="Center" Margin="0,0,6,0">
                                        <Ellipse.Fill>
                                            <SolidColorBrush Color="#10B981"/>
                                        </Ellipse.Fill>
                                        <Ellipse.Effect>
                                            <DropShadowEffect Color="#10B981" BlurRadius="6"
                                                              ShadowDepth="0" Opacity="0.9"/>
                                        </Ellipse.Effect>
                                    </Ellipse>
                                    <TextBlock Text="v1.0  ·  Ready"
                                               FontSize="10"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Navigation -->
                            <StackPanel>

                                <!-- Top gradient accent line -->
                                <Border Height="2" CornerRadius="0,0,1,1">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="Transparent" Offset="0"/>
                                            <GradientStop Color="#0A84FF" Offset="0.4"/>
                                            <GradientStop Color="#06B6D4" Offset="0.7"/>
                                            <GradientStop Color="Transparent" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect Color="#2563EB" BlurRadius="10"
                                                          ShadowDepth="0" Opacity="0.8"/>
                                    </Border.Effect>
                                </Border>



                                <!-- Section label -->
                                <TextBlock Text="TOOLS"
                                           FontSize="9"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Margin="20,16,0,4"/>

                                <!-- Generator nav button -->
                                <RadioButton x:Name="GeneratorNavButton"
                                             GroupName="SideNav"
                                             IsChecked="True"
                                             Tag="Generator"
                                             Style="{StaticResource SidebarNavButtonStyle}"
                                             Checked="NavButton_Checked">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="QrCode"
                                                                 Width="16" Height="16"
                                                                 VerticalAlignment="Center"
                                                                 Margin="0,0,10,0"/>
                                        <TextBlock Text="Generator" VerticalAlignment="Center" FontSize="13"/>
                                    </StackPanel>
                                </RadioButton>

                                <!-- Batch nav button -->
                                <RadioButton x:Name="BatchNavButton"
                                             GroupName="SideNav"
                                             Tag="Batch"
                                             Style="{StaticResource SidebarNavButtonStyle}"
                                             Checked="NavButton_Checked">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="FileMultiple"
                                                                 Width="16" Height="16"
                                                                 VerticalAlignment="Center"
                                                                 Margin="0,0,10,0"/>
                                        <TextBlock Text="Batch" VerticalAlignment="Center" FontSize="13"/>
                                    </StackPanel>
                                </RadioButton>

                                <!-- Presets nav button -->
                                <RadioButton x:Name="PresetsNavButton"
                                             GroupName="SideNav"
                                             Tag="Presets"
                                             Style="{StaticResource SidebarNavButtonStyle}"
                                             Checked="NavButton_Checked">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Star"
                                                                 Width="16" Height="16"
                                                                 VerticalAlignment="Center"
                                                                 Margin="0,0,10,0"/>
                                        <TextBlock Text="Presets" VerticalAlignment="Center" FontSize="13"/>
                                    </StackPanel>
                                </RadioButton>

                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Sidebar / content divider + splitter -->
                    <GridSplitter Grid.Column="1"
                                  Width="5"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  Background="{StaticResource BorderSubtleBrush}"
                                  Cursor="SizeWE"
                                  ResizeDirection="Columns"
                                  ResizeBehavior="PreviousAndNext"
                                  ShowsPreview="False"/>

                    <!-- ── CONTENT AREA ──────────────────────────── -->
                    <Grid Grid.Column="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="330" MinWidth="260" MaxWidth="560"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ── SETTINGS PANEL (left) ─────────── -->
                        <ScrollViewer Grid.Column="0"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="18,18,18,18">

                                <!-- ══════════════════════
                                     GENERATOR PANEL
                                ══════════════════════ -->
                                <StackPanel x:Name="GeneratorPanel" Visibility="Visible">

                                    <!-- ── QR Content Card ── -->
                                    <Border Margin="0,0,0,10"
                                            CornerRadius="14"
                                            Padding="16,14">
                                        <Border.Background>
                                            <SolidColorBrush Color="#0B1120"/>
                                        </Border.Background>
                                        <Border.BorderBrush>
                                            <SolidColorBrush Color="#1A2D4A"/>
                                        </Border.BorderBrush>
                                        <Border.BorderThickness>1</Border.BorderThickness>
                                        <StackPanel>
                                            <!-- Section header -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                <Border Width="26" Height="26" CornerRadius="7" Margin="0,0,9,0"><Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#0EA5E9" Offset="0"/><GradientStop Color="#0A84FF" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <materialDesign:PackIcon Kind="Pencil"
                                                                             Width="12" Height="12"
                                                                             HorizontalAlignment="Center"
                                                                             VerticalAlignment="Center"
                                                                             Foreground="White"/>
                                                </Border>
                                                <TextBlock Text="QR CONTENT"
                                                           Style="{StaticResource SectionLabelStyle}"
                                                           Margin="0"
                                                           VerticalAlignment="Center"
                                                           FontSize="10"
                                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                            </StackPanel>

                                            <!-- Payload type tabs -->
                                            <TabControl x:Name="PayloadTabControl"
                                                        Style="{StaticResource PillTabControlStyle}"
                                                        SelectionChanged="SettingChanged">

                                                <!-- Tab: Text / URL -->
                                                <TabItem Header="Text / URL">
                                                    <StackPanel Margin="0,2,0,0">
                                                        <TextBlock Text="URL or Text Content"
                                                                   Style="{StaticResource FieldLabelStyle}"/>
                                                        <TextBox x:Name="DataTextBox"
                                                                 Style="{StaticResource ModernTextBoxStyle}"
                                                                 TextChanged="SettingChanged"/>
                                                    </StackPanel>
                                                </TabItem>

                                                <!-- Tab: Wi-Fi -->
                                                <TabItem Header="Wi-Fi">
                                                    <StackPanel Margin="0,2,0,0">
                                                        <TextBlock Text="Network Name (SSID)"
                                                                   Style="{StaticResource FieldLabelStyle}"/>
                                                        <TextBox x:Name="WifiSsidTextBox"
                                                                 Style="{StaticResource ModernTextBoxStyle}"
                                                                 Margin="0,0,0,10"
                                                                 TextChanged="SettingChanged"/>

                                                        <TextBlock Text="Password"
                                                                   Style="{StaticResource FieldLabelStyle}"/>
                                                        <PasswordBox x:Name="WifiPasswordBox"
                                                                     Style="{StaticResource ModernPasswordBoxStyle}"
                                                                     Margin="0,0,0,10"
                                                                     PasswordChanged="SettingChanged"/>

                                                        <TextBlock Text="Security Type"
                                                                   Style="{StaticResource FieldLabelStyle}"/>
                                                        <ComboBox x:Name="WifiAuthComboBox"
                                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                                  SelectedIndex="1"
                                                                  Margin="0,0,0,10"
                                                                  SelectionChanged="SettingChanged">
                                                            <ComboBoxItem Content="WEP"/>
                                                            <ComboBoxItem Content="WPA"/>
                                                            <ComboBoxItem Content="WPA2"/>
                                                            <ComboBoxItem Content="No Password"/>
                                                        </ComboBox>

                                                        <CheckBox x:Name="WifiHiddenCheckBox"
                                                                  Content="Hidden network"
                                                                  Style="{StaticResource ModernCheckBoxStyle}"
                                                                  Checked="SettingChanged"
                                                                  Unchecked="SettingChanged"/>
                                                    </StackPanel>
                                                </TabItem>

                                                <!-- Tab: vCard -->
                                                <TabItem Header="vCard">
                                                    <StackPanel Margin="0,2,0,0">
                                                        <TextBlock Text="Full Name"
                                                                   Style="{StaticResource FieldLabelStyle}"/>
                                                        <TextBox x:Name="VCardFullNameTextBox"
                                                                 Style="{StaticResource ModernTextBoxStyle}"
                                                                 Margin="0,0,0,10"
                                                                 TextChanged="SettingChanged"/>

                                                        <TextBlock Text="Phone"
                                                                   Style="{StaticResource FieldLabelStyle}"/>
                                                        <TextBox x:Name="VCardPhoneTextBox"
                                                                 Style="{StaticResource ModernTextBoxStyle}"
                                                                 Margin="0,0,0,10"
                                                                 TextChanged="SettingChanged"/>

                                                        <TextBlock Text="Email"
                                                                   Style="{StaticResource FieldLabelStyle}"/>
                                                        <TextBox x:Name="VCardEmailTextBox"
                                                                 Style="{StaticResource ModernTextBoxStyle}"
                                                                 Margin="0,0,0,10"
                                                                 TextChanged="SettingChanged"/>

                                                        <TextBlock Text="Company"
                                                                   Style="{StaticResource FieldLabelStyle}"/>
                                                        <TextBox x:Name="VCardCompanyTextBox"
                                                                 Style="{StaticResource ModernTextBoxStyle}"
                                                                 TextChanged="SettingChanged"/>
                                                    </StackPanel>
                                                </TabItem>
                                            </TabControl>
                                        </StackPanel>
                                    </Border>

                                    <!-- ── Logo Card ── -->
                                    <Border Margin="0,0,0,10"
                                            CornerRadius="14"
                                            Padding="16,14">
                                        <Border.Background>
                                            <SolidColorBrush Color="#0B1120"/>
                                        </Border.Background>
                                        <Border.BorderBrush>
                                            <SolidColorBrush Color="#1A2D4A"/>
                                        </Border.BorderBrush>
                                        <Border.BorderThickness>1</Border.BorderThickness>
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                <Border Width="26" Height="26" CornerRadius="7" Margin="0,0,9,0">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#22D3EE" Offset="0"/>
                                                            <GradientStop Color="#0A84FF" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="#0A84FF" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                                                    </Border.Effect>
                                                    <materialDesign:PackIcon Kind="Image"
                                                                             Width="14" Height="14"
                                                                             HorizontalAlignment="Center"
                                                                             VerticalAlignment="Center"
                                                                             Foreground="White"/>
                                                </Border>
                                                <TextBlock Text="LOGO"
                                                           FontSize="10"
                                                           FontWeight="Bold"

                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>

                                            <!-- Logo file picker -->
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Hidden path holder -->
                                                <TextBox x:Name="LogoPathTextBox"
                                                         Visibility="Collapsed"
                                                         IsReadOnly="True"
                                                         TextChanged="LogoPath_TextChanged"/>

                                                <!-- File chip display -->
                                                <Border Grid.Column="0"
                                                        CornerRadius="8" BorderThickness="1" Height="34">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="#060C16"/>
                                                    </Border.Background>
                                                    <Border.BorderBrush>
                                                        <SolidColorBrush Color="#1A2D4A"/>
                                                    </Border.BorderBrush>
                                                    <Grid Margin="10,0,10,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <materialDesign:PackIcon x:Name="LogoFileIcon"
                                                                                 Grid.Column="0"
                                                                                 Kind="ImageOutline"
                                                                                 Width="14" Height="14"
                                                                                 Foreground="#2A4060"
                                                                                 VerticalAlignment="Center"
                                                                                 Margin="0,0,8,0"/>
                                                        <TextBlock x:Name="LogoFileNameDisplay"
                                                                   Grid.Column="1"
                                                                   Text="No file selected"
                                                                   Foreground="#2E4260"
                                                                   FontSize="12"
                                                                   VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </Grid>
                                                </Border>

                                                <!-- Browse button -->
                                                <Button x:Name="BrowseButton"
                                                        Grid.Column="1"
                                                        Style="{StaticResource GhostButtonStyle}"
                                                        Margin="8,0,0,0"
                                                        Click="BrowseButton_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon Kind="FolderOpen"
                                                                                 Width="13" Height="13"
                                                                                 VerticalAlignment="Center"
                                                                                 Margin="0,0,5,0"/>
                                                        <TextBlock Text="Browse" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>

                                                <!-- Clear / delete logo button -->
                                                <Button x:Name="ClearLogoButton"
                                                        Grid.Column="2"
                                                        Width="30" Height="30"
                                                        Margin="6,0,0,0"
                                                        ToolTip="Remove logo"
                                                        Cursor="Hand"
                                                        Click="ClearLogoButton_Click"
                                                        Style="{StaticResource MaterialDesignIconButton}"
                                                        Foreground="#9B3A55">
                                                    <materialDesign:PackIcon Kind="TrashCanOutline"
                                                                             Width="15" Height="15"/>
                                                </Button>
                                            </Grid>

                                            <!-- Logo size slider -->
                                            <TextBlock Text="Logo Size"
                                                       Style="{StaticResource FieldLabelStyle}"/>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Slider x:Name="LogoSizeSlider"
                                                        Grid.Column="0"
                                                        Minimum="10" Maximum="35" Value="15"
                                                        IsSnapToTickEnabled="True"
                                                        TickFrequency="1"
                                                        VerticalAlignment="Center"
                                                        Style="{StaticResource ModernSliderStyle}"
                                                        ValueChanged="SettingChanged"/>
                                                <Border Grid.Column="1"
                                                        Margin="10,0,0,0"
                                                        CornerRadius="8"
                                                        Padding="10,0"
                                                        MinWidth="50"
                                                        Height="30">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#040F22" Offset="0"/>
                                                            <GradientStop Color="#071428" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <Border.BorderBrush>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                            <GradientStop Color="#0A84FF" Offset="0"/>
                                                            <GradientStop Color="#06B6D4" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.BorderBrush>
                                                    <Border.BorderThickness>1</Border.BorderThickness>
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="#0A84FF" BlurRadius="8"
                                                                          ShadowDepth="0" Opacity="0.3"/>
                                                    </Border.Effect>
                                                    <TextBlock Text="{Binding Value, ElementName=LogoSizeSlider, StringFormat={}{0:0}%}"
                                                               FontSize="12"
                                                               FontWeight="Bold"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Foreground="{StaticResource AccentBrush}"/>
                                                </Border>
                                            </Grid>

                                            <CheckBox x:Name="LogoBackgroundCheckBox"
                                                      Content="Add background padding behind logo"
                                                      Style="{StaticResource ModernCheckBoxStyle}"
                                                      IsChecked="True"
                                                      Checked="SettingChanged"
                                                      Unchecked="SettingChanged"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- ── Styling Card ── -->
                                    <Border Margin="0,0,0,10"
                                            CornerRadius="14"
                                            Padding="16,14">
                                        <Border.Background>
                                            <SolidColorBrush Color="#0B1120"/>
                                        </Border.Background>
                                        <Border.BorderBrush>
                                            <SolidColorBrush Color="#1A2D4A"/>
                                        </Border.BorderBrush>
                                        <Border.BorderThickness>1</Border.BorderThickness>
                                        <StackPanel>
                                            <!-- Header -->
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Width="26" Height="26" CornerRadius="7" Margin="0,0,9,0">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="#0A84FF" Offset="0"/>
                                                                <GradientStop Color="#2563EB" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                        <Border.Effect>
                                                            <DropShadowEffect Color="#0A84FF" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                                                        </Border.Effect>
                                                        <materialDesign:PackIcon Kind="Palette"
                                                                                 Width="14" Height="14"
                                                                                 HorizontalAlignment="Center"
                                                                                 VerticalAlignment="Center"
                                                                                 Foreground="White"/>
                                                    </Border>
                                                    <TextBlock Text="STYLING"
                                                               FontSize="10"
                                                               FontWeight="Bold"

                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Color rows -->
                                            <local:ColorRow x:Name="FgColorRow"
                                                            Label="Foreground"
                                                            InitialColor="#FF000000"
                                                            Margin="0,0,0,10"
                                                            ColorChanged="ColorRow_ColorChanged"/>

                                            <CheckBox x:Name="UseGradientCheckBox"
                                                      Content="Use Gradient"
                                                      Style="{StaticResource ModernCheckBoxStyle}"
                                                      Margin="0,0,0,10"
                                                      Checked="SettingChanged"
                                                      Unchecked="SettingChanged"/>

                                            <local:ColorRow x:Name="FgColor2Row"
                                                            Label="Foreground 2"
                                                            InitialColor="#FF3F51B5"
                                                            Margin="0,0,0,10"
                                                            Visibility="{Binding IsChecked, ElementName=UseGradientCheckBox, Converter={StaticResource BoolToVisibility}}"
                                                            ColorChanged="ColorRow_ColorChanged"/>

                                            <local:ColorRow x:Name="BgColorRow"
                                                            Label="Background"
                                                            InitialColor="#FFFFFFFF"
                                                            Margin="0,0,0,10"
                                                            ColorChanged="ColorRow_ColorChanged"/>

                                            <local:ColorRow x:Name="FinderColorRow"
                                                            Label="Finder Pattern"
                                                            InitialColor="#FF000000"
                                                            Margin="0,0,0,10"
                                                            ColorChanged="ColorRow_ColorChanged"/>

                                            <local:ColorRow x:Name="InnerEyeColorRow"
                                                            Label="Inner Eye"
                                                            InitialColor="#FF000000"
                                                            Margin="0,0,0,14"
                                                            ColorChanged="ColorRow_ColorChanged"/>

                                            <!-- Divider -->
                                            <Border Height="1"
                                                    Margin="0,0,0,12">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="Transparent" Offset="0"/>
                                                        <GradientStop Color="#1A2D4A" Offset="0.5"/>
                                                        <GradientStop Color="Transparent" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>

                                            <!-- Eye shape -->
                                            <TextBlock Text="Eye Shape"
                                                       Style="{StaticResource FieldLabelStyle}"/>
                                            <ComboBox x:Name="EyeShapeComboBox"
                                                      Style="{StaticResource ModernComboBoxStyle}"
                                                      helpers:ComboBoxAssist.PopupPlacement="Top"
                                                      SelectedIndex="0"
                                                      Margin="0,0,0,10"
                                                      SelectionChanged="SettingChanged">
                                                <ComboBoxItem Content="Square"/>
                                                <ComboBoxItem Content="Rounded"/>
                                                <ComboBoxItem Content="Circular"/>
                                                <ComboBoxItem Content="Leaf"/>
                                                <ComboBoxItem Content="Shield"/>
                                            </ComboBox>

                                            <!-- Module shape -->
                                            <TextBlock Text="Module Shape"
                                                       Style="{StaticResource FieldLabelStyle}"/>
                                            <ComboBox x:Name="ShapeComboBox"
                                                      Style="{StaticResource ModernComboBoxStyle}"
                                                      helpers:ComboBoxAssist.PopupPlacement="Top"
                                                      SelectedIndex="0"
                                                      SelectionChanged="SettingChanged">
                                                <ComboBoxItem Content="Squares"/>
                                                <ComboBoxItem Content="Rounded Squares"/>
                                                <ComboBoxItem Content="Dots / Circles"/>
                                                <ComboBoxItem Content="Liquid"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </Border>

                                </StackPanel><!-- /GeneratorPanel -->

                                <!-- ══════════════════════
                                     BATCH PANEL
                                ══════════════════════ -->
                                <StackPanel x:Name="BatchPanel" Visibility="Collapsed">

                                    <Border Margin="0,0,0,10"
                                            CornerRadius="14"
                                            Padding="16,14">
                                        <Border.Background>
                                            <SolidColorBrush Color="#0B1120"/>
                                        </Border.Background>
                                        <Border.BorderBrush>
                                            <SolidColorBrush Color="#1A2D4A"/>
                                        </Border.BorderBrush>
                                        <Border.BorderThickness>1</Border.BorderThickness>
                                        <StackPanel>
                                            <!-- Header -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                <Border Width="24" Height="24" CornerRadius="6" Margin="0,0,8,0">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#0A84FF" Offset="0"/>
                                                            <GradientStop Color="#06B6D4" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <materialDesign:PackIcon Kind="FileMultiple"
                                                                             Width="12" Height="12"
                                                                             HorizontalAlignment="Center"
                                                                             VerticalAlignment="Center"
                                                                             Foreground="White"/>
                                                </Border>
                                                <TextBlock Text="BATCH PROCESSING"
                                                           FontSize="10"
                                                           FontWeight="Bold"

                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>

                                            <!-- Info hint -->
                                            <Border CornerRadius="8"
                                                    Padding="12,8"
                                                    Margin="0,0,0,14">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#051830" Offset="0"/>
                                                        <GradientStop Color="#0A1E38" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <Border.BorderBrush>
                                                    <SolidColorBrush Color="#2A4068"/>
                                                </Border.BorderBrush>
                                                <Border.BorderThickness>1</Border.BorderThickness>
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="InformationOutline"
                                                                             Width="14" Height="14"
                                                                             Foreground="{StaticResource AccentBrush}"
                                                                             VerticalAlignment="Top"
                                                                             Margin="0,1,8,0"/>
                                                    <TextBlock Text="CSV format: data (required), filename (optional)"
                                                               FontSize="11"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- CSV file picker -->
                                            <TextBlock Text="CSV File"
                                                       Style="{StaticResource FieldLabelStyle}"/>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="BatchCsvPathTextBox"
                                                         Grid.Column="0"
                                                         Style="{StaticResource ModernTextBoxStyle}"
                                                         IsReadOnly="True"
                                                         Text="{Binding CsvPath, Mode=TwoWay}"/>
                                                <Button x:Name="BatchBrowseCsvButton"
                                                        Grid.Column="1"
                                                        Style="{StaticResource GhostButtonStyle}"
                                                        Margin="8,0,0,0"
                                                        Command="{Binding BrowseCsvCommand}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon Kind="FolderOpen"
                                                                                 Width="13" Height="13"
                                                                                 VerticalAlignment="Center"
                                                                                 Margin="0,0,5,0"/>
                                                        <TextBlock Text="Browse" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                            </Grid>

                                            <!-- Output folder -->
                                            <TextBlock Text="Output Folder"
                                                       Style="{StaticResource FieldLabelStyle}"/>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="BatchOutputFolderTextBox"
                                                         Grid.Column="0"
                                                         Style="{StaticResource ModernTextBoxStyle}"
                                                         IsReadOnly="True"
                                                         Text="{Binding OutputFolder, Mode=TwoWay}"/>
                                                <Button x:Name="BatchBrowseOutputButton"
                                                        Grid.Column="1"
                                                        Style="{StaticResource GhostButtonStyle}"
                                                        Margin="8,0,0,0"
                                                        Command="{Binding BrowseOutputFolderCommand}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon Kind="FolderOpen"
                                                                                 Width="13" Height="13"
                                                                                 VerticalAlignment="Center"
                                                                                 Margin="0,0,5,0"/>
                                                        <TextBlock Text="Browse" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                            </Grid>

                                            <!-- Output format -->
                                            <TextBlock Text="Output Format"
                                                       Style="{StaticResource FieldLabelStyle}"/>
                                            <ComboBox x:Name="BatchOutputFormatComboBox"
                                                      Style="{StaticResource ModernComboBoxStyle}"
                                                      ItemsSource="{Binding OutputFormats}"
                                                      SelectedItem="{Binding SelectedOutputFormat, Mode=TwoWay}"
                                                      Margin="0,0,0,14"/>

                                            <!-- Divider -->
                                            <Border Height="1" Margin="0,0,0,12">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="Transparent" Offset="0"/>
                                                        <GradientStop Color="#1A2D4A" Offset="0.5"/>
                                                        <GradientStop Color="Transparent" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>

                                            <!-- Progress -->
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Progress"
                                                           Style="{StaticResource FieldLabelStyle}"
                                                           Margin="0"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock x:Name="BatchStatusTextBlock"
                                                           Grid.Column="1"
                                                           Text="{Binding StatusText}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                            <ProgressBar x:Name="BatchProgressBar"
                                                         Style="{StaticResource ModernProgressBarStyle}"
                                                         Minimum="0" Maximum="100"
                                                         Value="{Binding Progress, Mode=OneWay}"
                                                         Margin="0,0,0,14"/>

                                            <!-- Start / Cancel -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="10"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Button x:Name="BatchStartButton"
                                                        Grid.Column="0"
                                                        Style="{StaticResource PrimaryButtonStyle}"
                                                        Command="{Binding StartBatchCommand}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon Kind="Play"
                                                                                 Width="15" Height="15"
                                                                                 VerticalAlignment="Center"
                                                                                 Margin="0,0,7,0"/>
                                                        <TextBlock Text="Start Batch"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button x:Name="BatchCancelButton"
                                                        Grid.Column="2"
                                                        Style="{StaticResource OutlineButtonStyle}"
                                                        Command="{Binding CancelBatchCommand}">
                                                    Cancel
                                                </Button>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                </StackPanel><!-- /BatchPanel -->

                                <!-- ══════════════════════
                                     PRESETS PANEL
                                ══════════════════════ -->
                                <StackPanel x:Name="PresetsPanel" Visibility="Collapsed">

                                    <Border Margin="0,0,0,10"
                                            CornerRadius="14"
                                            Padding="16,14">
                                        <Border.Background>
                                            <SolidColorBrush Color="#0B1120"/>
                                        </Border.Background>
                                        <Border.BorderBrush>
                                            <SolidColorBrush Color="#1A2D4A"/>
                                        </Border.BorderBrush>
                                        <Border.BorderThickness>1</Border.BorderThickness>
                                        <StackPanel>
                                            <!-- Header -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                <Border Width="24" Height="24" CornerRadius="6" Margin="0,0,8,0">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#0A84FF" Offset="0"/>
                                                            <GradientStop Color="#06B6D4" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <materialDesign:PackIcon Kind="Star"
                                                                             Width="12" Height="12"
                                                                             HorizontalAlignment="Center"
                                                                             VerticalAlignment="Center"
                                                                             Foreground="White"/>
                                                </Border>
                                                <TextBlock Text="STYLE PRESETS"
                                                           FontSize="10"
                                                           FontWeight="Bold"

                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>

                                            <TextBlock Text="Save and reuse styling presets."
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,12"/>

                                            <!-- Save / Load buttons -->
                                            <Grid Margin="0,0,0,14">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="10"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Button x:Name="PresetSaveButton"
                                                          Grid.Column="0"
                                                          Style="{StaticResource PrimaryButtonStyle}"
                                                          Click="PresetSaveButton_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon Kind="ContentSave"
                                                                                 Width="15" Height="15"
                                                                                 VerticalAlignment="Center"
                                                                                 Margin="0,0,7,0"/>
                                                        <TextBlock Text="Save" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button x:Name="PresetLoadButton"
                                                        Grid.Column="2"
                                                        Style="{StaticResource OutlineButtonStyle}"
                                                        IsEnabled="False"
                                                        Click="PresetLoadButton_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon Kind="Download"
                                                                                 Width="15" Height="15"
                                                                                 VerticalAlignment="Center"
                                                                                 Margin="0,0,7,0"/>
                                                        <TextBlock Text="Load" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                            </Grid>

                                            <!-- Divider -->
                                            <Border Height="1" Margin="0,0,0,12">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="Transparent" Offset="0"/>
                                                        <GradientStop Color="#1A2D4A" Offset="0.5"/>
                                                        <GradientStop Color="Transparent" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>

                                            <TextBlock Text="Saved Records"
                                                       Style="{StaticResource FieldLabelStyle}"/>

                                            <ListBox x:Name="PresetListBox"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     Padding="0"
                                                     MaxHeight="260"
                                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                     SelectionChanged="PresetListBox_SelectionChanged">
                                                <ListBox.ItemContainerStyle>
                                                    <Style TargetType="ListBoxItem">
                                                        <Setter Property="Padding" Value="0"/>
                                                        <Setter Property="Margin" Value="0,0,0,8"/>
                                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="ListBoxItem">
                                                                    <Border x:Name="ItemBorder"
                                                                            Background="{TemplateBinding Background}"
                                                                            BorderBrush="{StaticResource BorderSubtleBrush}"
                                                                            BorderThickness="1"
                                                                            CornerRadius="9"
                                                                            Padding="10">
                                                                        <ContentPresenter/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource BorderMidBrush}"/>
                                                                            <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource Surface2Brush}"/>
                                                                        </Trigger>
                                                                        <Trigger Property="IsSelected" Value="True">
                                                                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                                            <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource AccentSubtleBrush}"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </ListBox.ItemContainerStyle>
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <Border Grid.Column="0"
                                                                    Width="28" Height="28"
                                                                    CornerRadius="8"
                                                                    Margin="0,0,10,0"
                                                                    Background="{StaticResource Surface3Brush}">
                                                                <materialDesign:PackIcon Kind="Bookmark"
                                                                                         Width="14" Height="14"
                                                                                         HorizontalAlignment="Center"
                                                                                         VerticalAlignment="Center"
                                                                                         Foreground="{StaticResource AccentBrush}"/>
                                                            </Border>

                                                            <StackPanel Grid.Column="1"
                                                                        VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Name}"
                                                                           FontSize="13"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Text="{Binding UpdatedUtc, StringFormat={}{0:MMM d, h:mm tt}}"
                                                                           FontSize="10"
                                                                           Foreground="{StaticResource TextMutedBrush}"
                                                                           Margin="0,2,0,0"/>
                                                            </StackPanel>

                                                            <Button Grid.Column="2"
                                                                    Width="32"
                                                                    Height="32"
                                                                    Padding="0"
                                                                    Margin="8,0,0,0"
                                                                    Style="{StaticResource GhostButtonStyle}"
                                                                    ToolTip="Delete"
                                                                    Tag="{Binding}"
                                                                    Click="PresetRecordDeleteButton_Click">
                                                                <materialDesign:PackIcon Kind="TrashCanOutline"
                                                                                         Width="15" Height="15"
                                                                                         Foreground="{StaticResource DangerBrush}"/>
                                                            </Button>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>

                                            <TextBlock x:Name="PresetEmptyText"
                                                       Text="No saved records"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,8,0,0"
                                                       Visibility="Collapsed"/>
                                        </StackPanel>
                                    </Border>

                                </StackPanel><!-- /PresetsPanel -->

                            </StackPanel>
                        </ScrollViewer>

                        <!-- Settings / Preview divider + splitter -->
                        <GridSplitter Grid.Column="1"
                                      Width="5"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch"
                                      Background="{StaticResource BorderSubtleBrush}"
                                      Cursor="SizeWE"
                                      ResizeDirection="Columns"
                                      ResizeBehavior="PreviousAndNext"
                                      ShowsPreview="False"/>

                        <!-- ── PREVIEW PANEL (right) ─────────── -->
                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- QR Preview Area -->
                            <Border Grid.Row="0"
                                    Margin="0"
                                    ClipToBounds="True">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#080C14" Offset="0"/>
                                        <GradientStop Color="#0B1120" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>

                                <Grid>
                                    <!-- Decorative background circles -->
                                    <Canvas IsHitTestVisible="False">
                                        <Ellipse Width="300" Height="300"
                                                 Canvas.Left="-50" Canvas.Top="-80"
                                                 Opacity="0.04">
                                            <Ellipse.Fill>
                                                <RadialGradientBrush>
                                                    <GradientStop Color="#0A84FF" Offset="0"/>
                                                    <GradientStop Color="Transparent" Offset="1"/>
                                                </RadialGradientBrush>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <Ellipse Width="250" Height="250"
                                                 Canvas.Right="-40" Canvas.Bottom="-60"
                                                 Opacity="0.05">
                                            <Ellipse.Fill>
                                                <RadialGradientBrush>
                                                    <GradientStop Color="#06B6D4" Offset="0"/>
                                                    <GradientStop Color="Transparent" Offset="1"/>
                                                </RadialGradientBrush>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                    </Canvas>

                                    <Button x:Name="ResetButton"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Margin="0,18,18,0"
                                            Height="34"
                                            Padding="12,0"
                                            FontSize="12"
                                            Panel.ZIndex="3"
                                            Style="{StaticResource GhostButtonStyle}"
                                            ToolTip="Reset all settings"
                                            Click="ResetButton_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Refresh"
                                                                     Width="14" Height="14"
                                                                     VerticalAlignment="Center"
                                                                     Margin="0,0,6,0"/>
                                            <TextBlock Text="Reset" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Empty state hint -->
                                    <Border x:Name="EmptyHint"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                        <StackPanel HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <!-- Dashed box -->
                                            <Grid Width="240" Height="240" Margin="0,0,0,20">
                                                <Rectangle RadiusX="20" RadiusY="20"
                                                           Stroke="#243454"
                                                           StrokeThickness="1.5"
                                                           StrokeDashArray="5 4"/>
                                                <StackPanel HorizontalAlignment="Center"
                                                            VerticalAlignment="Center">
                                                    <!-- Icon container with gradient -->
                                                    <Border Width="60" Height="60" CornerRadius="16"
                                                            Margin="0,0,0,14"
                                                            HorizontalAlignment="Center">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="#0A1E38" Offset="0"/>
                                                                <GradientStop Color="#251E50" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                        <Border.BorderBrush>
                                                            <SolidColorBrush Color="#2A4068"/>
                                                        </Border.BorderBrush>
                                                        <Border.BorderThickness>1</Border.BorderThickness>
                                                        <materialDesign:PackIcon Kind="QrCode"
                                                                                 Width="30" Height="30"
                                                                                 HorizontalAlignment="Center"
                                                                                 VerticalAlignment="Center"
                                                                                 Foreground="{StaticResource TextMutedBrush}"/>
                                                    </Border>
                                                    <TextBlock Text="Enter content to generate"
                                                               FontSize="13"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               HorizontalAlignment="Center"/>
                                                    <TextBlock Text="a QR code"
                                                               FontSize="13"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Hint chips -->
                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Center">
                                                <Border CornerRadius="20" Padding="10,5" Margin="4,0">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="#0F1828"/>
                                                    </Border.Background>
                                                    <Border.BorderBrush>
                                                        <SolidColorBrush Color="#1A2D4A"/>
                                                    </Border.BorderBrush>
                                                    <Border.BorderThickness>1</Border.BorderThickness>
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon Kind="LinkVariant"
                                                                                 Width="12" Height="12"
                                                                                 Foreground="{StaticResource AccentBrush}"
                                                                                 VerticalAlignment="Center"
                                                                                 Margin="0,0,5,0"/>
                                                        <TextBlock Text="URL" FontSize="10"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border CornerRadius="20" Padding="10,5" Margin="4,0">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="#0F1828"/>
                                                    </Border.Background>
                                                    <Border.BorderBrush>
                                                        <SolidColorBrush Color="#1A2D4A"/>
                                                    </Border.BorderBrush>
                                                    <Border.BorderThickness>1</Border.BorderThickness>
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon Kind="Wifi"
                                                                                 Width="12" Height="12"
                                                                                 Foreground="{StaticResource AccentBrush}"
                                                                                 VerticalAlignment="Center"
                                                                                 Margin="0,0,5,0"/>
                                                        <TextBlock Text="Wi-Fi" FontSize="10"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    </StackPanel>
                                                </Border>
                                                <Border CornerRadius="20" Padding="10,5" Margin="4,0">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="#0F1828"/>
                                                    </Border.Background>
                                                    <Border.BorderBrush>
                                                        <SolidColorBrush Color="#1A2D4A"/>
                                                    </Border.BorderBrush>
                                                    <Border.BorderThickness>1</Border.BorderThickness>
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon Kind="Card"
                                                                                 Width="12" Height="12"
                                                                                 Foreground="{StaticResource AccentBrush}"
                                                                                 VerticalAlignment="Center"
                                                                                 Margin="0,0,5,0"/>
                                                        <TextBlock Text="vCard" FontSize="10"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Live QR code image -->
                                    <Border x:Name="QrImageCard"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ElementName=EmptyHint, Path=Visibility}" Value="Visible">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <!-- QR card with glow -->
                                        <Border Background="{StaticResource SurfaceBrush}"
                                                BorderBrush="{StaticResource BorderSubtleBrush}"
                                                BorderThickness="1"
                                                CornerRadius="20"
                                                Padding="28"
                                                SnapsToDevicePixels="True">
                                            <Border.Effect>
                                                <DropShadowEffect Color="#0A84FF"
                                                                  BlurRadius="40"
                                                                  ShadowDepth="0"
                                                                  Opacity="0.25"/>
                                            </Border.Effect>
                                            <Image x:Name="QrCodeImage"
                                                   Stretch="Uniform"
                                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                                   MaxWidth="340"
                                                   MaxHeight="340"/>
                                        </Border>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- Export action buttons -->
                            <Border Grid.Row="1"
                                    Padding="24,14,24,18">
                                <Border.Background>
                                    <SolidColorBrush Color="#080E1C"/>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="#1A1440"/>
                                </Border.BorderBrush>
                                <Border.BorderThickness>0,1,0,0</Border.BorderThickness>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            x:Name="SaveButton"
                                            Height="46"
                                            IsEnabled="False"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Click="SaveButton_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="ContentSave"
                                                                     Width="17" Height="17"
                                                                     VerticalAlignment="Center"
                                                                     Margin="0,0,9,0"/>
                                            <TextBlock Text="Save PNG"
                                                       FontSize="13"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <Button Grid.Column="2"
                                            x:Name="ExportSvgButton"
                                            Height="46"
                                            IsEnabled="False"
                                            Style="{StaticResource OutlineButtonStyle}"
                                            Click="ExportSvgButton_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="FileCode"
                                                                     Width="17" Height="17"
                                                                     VerticalAlignment="Center"
                                                                     Margin="0,0,9,0"/>
                                            <TextBlock Text="Export SVG"
                                                       FontSize="13"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>

                        </Grid><!-- /Preview Panel -->

                    </Grid><!-- /Content Grid -->
                </Grid><!-- /Row 1 Grid -->

            </Grid><!-- /Main Grid -->
        </materialDesign:DialogHost>
