<Window x:Class="CortexQR.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:CortexQR.Views"
        Title="Cortex QR" Height="680" Width="860"
        MinWidth="760" MinHeight="580"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        Background="Transparent"
        TextElement.Foreground="#E0E0E0"
        TextElement.FontFamily="{materialDesign:MaterialDesignFont}"
        FontSize="14">

    <Window.Resources>
        <Style x:Key="ColorLabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBodyLight}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="ChromeButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="#D7D7D7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ChromeButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ChromeButtonBorder" Property="Background" Value="#2DFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ChromeButtonBorder" Property="Background" Value="#45FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#121212">
        <materialDesign:DialogHost Identifier="RootDialog"
                                   CloseOnClickAway="True"
                                   DialogMargin="24">
            <materialDesign:DialogHost.OverlayBackground>
                <SolidColorBrush Color="#CC000000"/>
            </materialDesign:DialogHost.OverlayBackground>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border x:Name="HeaderBar"
                        Grid.Row="0"
                        Background="#1E1E1E"
                        Padding="24,12"
                        MouseLeftButtonDown="HeaderBar_MouseLeftButtonDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="36" Height="36"
                                CornerRadius="8"
                                Background="{DynamicResource PrimaryHueMidBrush}"
                                Margin="0,0,14,0">
                            <materialDesign:PackIcon Kind="QrCode"
                                                     Width="22" Height="22"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     Foreground="White"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Cortex QR"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="White"/>
                            <TextBlock Text="Professional QR Code Generator"
                                       FontSize="11"
                                       Foreground="#AAFFFFFF"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Top"
                                    Margin="16,0,0,0">
                            <Button x:Name="MinimizeButton"
                                    Style="{StaticResource ChromeButtonStyle}"
                                    ToolTip="Minimize"
                                    Click="MinimizeButton_Click">
                                <materialDesign:PackIcon Kind="WindowMinimize"
                                                         Width="16" Height="16"/>
                            </Button>
                            <Button x:Name="CloseButton"
                                    Style="{StaticResource ChromeButtonStyle}"
                                    ToolTip="Close"
                                    Click="CloseButton_Click">
                                <materialDesign:PackIcon Kind="Close"
                                                         Width="16" Height="16"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360" MinWidth="300"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel>

                            <materialDesign:Card Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="QR CONTENT"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryHueMidBrush}"
                                               Margin="0,0,0,14"/>

                                    <TextBox x:Name="DataTextBox"
                                             materialDesign:HintAssist.Hint="Enter URL or text..."
                                             materialDesign:HintAssist.IsFloating="True"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             AcceptsReturn="False"
                                             MaxLines="1"
                                             FontSize="14"
                                             TextChanged="SettingChanged"/>
                                </StackPanel>
                            </materialDesign:Card>

                            <materialDesign:Card Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="LOGO"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryHueMidBrush}"
                                               Margin="0,0,0,14"/>

                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="LogoPathTextBox"
                                                 Grid.Column="0"
                                                 materialDesign:HintAssist.Hint="No logo selected"
                                                 materialDesign:HintAssist.IsFloating="True"
                                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                 IsReadOnly="True"
                                                 FontSize="12"
                                                 Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                 TextChanged="SettingChanged"/>
                                        <Button x:Name="BrowseButton"
                                                Grid.Column="1"
                                                Content="BROWSE"
                                                Margin="10,0,0,0"
                                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                                Padding="14,0"
                                                Height="40"
                                                Click="BrowseButton_Click"
                                                Cursor="Hand"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Slider x:Name="LogoSizeSlider"
                                                Grid.Column="0"
                                                Minimum="10"
                                                Maximum="35"
                                                Value="15"
                                                IsSnapToTickEnabled="True"
                                                TickFrequency="1"
                                                Style="{StaticResource MaterialDesignSlider}"
                                                VerticalAlignment="Center"
                                                ValueChanged="SettingChanged"/>
                                        <Border Grid.Column="1"
                                                Margin="10,0,0,0"
                                                Background="{DynamicResource PrimaryHueLightBrush}"
                                                CornerRadius="12"
                                                Padding="8,2"
                                                MinWidth="44">
                                            <TextBlock Text="{Binding Value, ElementName=LogoSizeSlider, StringFormat={}{0:0}%}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       Foreground="{DynamicResource PrimaryHueLightForegroundBrush}"/>
                                        </Border>
                                    </Grid>

                                    <CheckBox x:Name="LogoBackgroundCheckBox"
                                              Content="Add background padding behind logo"
                                              IsChecked="True"
                                              Style="{StaticResource MaterialDesignCheckBox}"
                                              Checked="SettingChanged"
                                              Unchecked="SettingChanged"/>
                                </StackPanel>
                            </materialDesign:Card>

                            <materialDesign:Card Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="STYLING"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                   VerticalAlignment="Center"/>
                                        <Button x:Name="ResetButton"
                                                Grid.Column="1"
                                                Height="30"
                                                Padding="8,0"
                                                Style="{StaticResource MaterialDesignFlatButton}"
                                                Foreground="{DynamicResource PrimaryHueLightBrush}"
                                                ToolTip="Restore defaults"
                                                Click="ResetButton_Click"
                                                Cursor="Hand">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="Refresh"
                                                                         Width="16" Height="16"
                                                                         VerticalAlignment="Center"
                                                                         Margin="0,0,6,0"/>
                                                <TextBlock Text="Reset"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>

                                    <local:ColorRow x:Name="FgColorRow"
                                                    Label="Foreground"
                                                    InitialColor="#FF000000"
                                                    Margin="0,0,0,14"
                                                    ColorChanged="ColorRow_ColorChanged"/>

                                    <local:ColorRow x:Name="BgColorRow"
                                                    Label="Background"
                                                    InitialColor="#FFFFFFFF"
                                                    Margin="0,0,0,14"
                                                    ColorChanged="ColorRow_ColorChanged"/>

                                    <local:ColorRow x:Name="FinderColorRow"
                                                    Label="Finder Pattern"
                                                    InitialColor="#FF000000"
                                                    Margin="0,0,0,14"
                                                    ColorChanged="ColorRow_ColorChanged"/>

                                    <local:ColorRow x:Name="InnerEyeColorRow"
                                                    Label="Inner Eye Color"
                                                    InitialColor="#FF000000"
                                                    Margin="0,0,0,16"
                                                    ColorChanged="ColorRow_ColorChanged"/>

                                    <Separator Margin="0,0,0,14"
                                               Background="{DynamicResource MaterialDesignDivider}"/>

                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="Eye Shape"
                                                   Style="{StaticResource ColorLabelStyle}"
                                                   Width="110"/>
                                        <ComboBox x:Name="EyeShapeComboBox"
                                                  Grid.Column="1"
                                                  SelectedIndex="0"
                                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                                  SelectionChanged="SettingChanged">
                                            <ComboBoxItem Content="Square"/>
                                            <ComboBoxItem Content="Rounded"/>
                                            <ComboBoxItem Content="Circular"/>
                                        </ComboBox>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="Module Shape"
                                                   Style="{StaticResource ColorLabelStyle}"
                                                   Width="110"/>
                                        <ComboBox x:Name="ShapeComboBox"
                                                  Grid.Column="1"
                                                  SelectedIndex="0"
                                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                                  SelectionChanged="SettingChanged">
                                            <ComboBoxItem Content="Squares"/>
                                            <ComboBoxItem Content="Rounded Squares"/>
                                            <ComboBoxItem Content="Dots / Circles"/>
                                        </ComboBox>
                                    </Grid>
                                </StackPanel>
                            </materialDesign:Card>

                        </StackPanel>
                    </ScrollViewer>

                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <materialDesign:Card Grid.Row="0"
                                             UniformCornerRadius="12"
                                             Background="#FFFFFF"
                                             Margin="0,0,0,16">
                            <Grid>
                                <TextBlock x:Name="EmptyHint"
                                           Text="Enter content to generate a QR code"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource MaterialDesignBodyLight}"
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           Margin="30"/>

                                <Image x:Name="QrCodeImage"
                                       Stretch="Uniform"
                                       Margin="24"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                            </Grid>
                        </materialDesign:Card>

                        <Button Grid.Row="1"
                                x:Name="SaveButton"
                                Height="48"
                                IsEnabled="False"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="{DynamicResource PrimaryHueMidBrush}"
                                Foreground="White"
                                FontSize="15"
                                FontWeight="Bold"
                                materialDesign:ButtonAssist.CornerRadius="10"
                                Click="SaveButton_Click"
                                Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ContentSave"
                                                         Width="20" Height="20"
                                                         VerticalAlignment="Center"
                                                         Margin="0,0,10,0"/>
                                <TextBlock Text="Save QR Code" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Grid>
        </materialDesign:DialogHost>
    </Border>
</Window>
