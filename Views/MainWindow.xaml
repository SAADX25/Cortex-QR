<Window x:Class="CortexQR.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:CortexQR.Views"
        Title="Cortex QR" Height="740" Width="1060"
        MinWidth="900" MinHeight="620"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize"
        Background="Transparent"
        TextElement.Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="{materialDesign:MaterialDesignFont}"
        FontSize="14">

    <!-- Root border creates the rounded window shape -->
    <Border Background="{StaticResource SurfaceBrush}"
            CornerRadius="10"
            ClipToBounds="True">

        <materialDesign:DialogHost Identifier="RootDialog"
                                   CloseOnClickAway="True"
                                   DialogMargin="24">
            <materialDesign:DialogHost.OverlayBackground>
                <SolidColorBrush Color="#CC000000"/>
            </materialDesign:DialogHost.OverlayBackground>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="52"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ══════════════════════════════════════════════════
                     ROW 0 — Custom title bar / chrome
                ══════════════════════════════════════════════════ -->
                <Border x:Name="HeaderBar"
                        Grid.Row="0"
                        Background="{StaticResource Surface1Brush}"
                        MouseLeftButtonDown="HeaderBar_MouseLeftButtonDown">
                    <!-- Bottom divider line -->
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#2A2A3A"/>
                    </Border.BorderBrush>
                    <Border.BorderThickness>0,0,0,1</Border.BorderThickness>

                    <Grid Margin="20,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Logo + App Name -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="34" Height="34" CornerRadius="8" Margin="0,0,12,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#7C6AF7" Offset="0"/>
                                        <GradientStop Color="#5548C8" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <materialDesign:PackIcon Kind="QrCode"
                                                         Width="20" Height="20"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"
                                                         Foreground="White"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="CORTEX QR"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="Professional QR Studio"
                                           FontSize="11"
                                           Foreground="{StaticResource TextMutedBrush}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Window Chrome Buttons -->
                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button x:Name="MinimizeButton"
                                    Style="{StaticResource ChromeButtonStyle}"
                                    ToolTip="Minimize"
                                    Click="MinimizeButton_Click">
                                <materialDesign:PackIcon Kind="WindowMinimize" Width="16" Height="16"/>
                            </Button>
                            <Button x:Name="MaximizeButton"
                                    Style="{StaticResource ChromeButtonStyle}"
                                    ToolTip="Maximize"
                                    Margin="2,0,0,0"
                                    Click="MaximizeButton_Click">
                                <materialDesign:PackIcon Kind="WindowMaximize" Width="16" Height="16"/>
                            </Button>
                            <Button x:Name="CloseButton"
                                    Style="{StaticResource CloseButtonStyle}"
                                    ToolTip="Close"
                                    Margin="2,0,0,0"
                                    Click="CloseButton_Click">
                                <materialDesign:PackIcon Kind="Close" Width="16" Height="16"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ══════════════════════════════════════════════════
                     ROW 1 — Sidebar + Content area
                ══════════════════════════════════════════════════ -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ── SIDEBAR ──────────────────────────────────── -->
                    <Border Grid.Column="0"
                            Background="{StaticResource Surface1Brush}">
                        <DockPanel>
                            <!-- Version label docked at the bottom -->
                            <TextBlock DockPanel.Dock="Bottom"
                                       Text="Cortex QR · v1.0"
                                       FontSize="10"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,16"/>

                            <!-- Navigation -->
                            <StackPanel Margin="0,24,0,0">
                                <!-- Sidebar branding mark -->
                                <StackPanel Orientation="Horizontal" Margin="20,0,0,24">
                                    <Border Width="8" Height="8" CornerRadius="4"
                                            Margin="0,0,8,0" VerticalAlignment="Center">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#7C6AF7" Offset="0"/>
                                                <GradientStop Color="#5548C8" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <TextBlock Text="WORKSPACE"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Generator nav button -->
                                <RadioButton x:Name="GeneratorNavButton"
                                             GroupName="SideNav"
                                             IsChecked="True"
                                             Tag="Generator"
                                             Style="{StaticResource SidebarNavButtonStyle}"
                                             Checked="NavButton_Checked">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="QrCode"
                                                                 Width="20" Height="20"
                                                                 VerticalAlignment="Center"
                                                                 Margin="0,0,12,0"/>
                                        <TextBlock Text="Generator" VerticalAlignment="Center" FontSize="13"/>
                                    </StackPanel>
                                </RadioButton>

                                <!-- Batch nav button -->
                                <RadioButton x:Name="BatchNavButton"
                                             GroupName="SideNav"
                                             Tag="Batch"
                                             Style="{StaticResource SidebarNavButtonStyle}"
                                             Checked="NavButton_Checked">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="FileMultiple"
                                                                 Width="20" Height="20"
                                                                 VerticalAlignment="Center"
                                                                 Margin="0,0,12,0"/>
                                        <TextBlock Text="Batch" VerticalAlignment="Center" FontSize="13"/>
                                    </StackPanel>
                                </RadioButton>

                                <!-- Presets nav button -->
                                <RadioButton x:Name="PresetsNavButton"
                                             GroupName="SideNav"
                                             Tag="Presets"
                                             Style="{StaticResource SidebarNavButtonStyle}"
                                             Checked="NavButton_Checked">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Star"
                                                                 Width="20" Height="20"
                                                                 VerticalAlignment="Center"
                                                                 Margin="0,0,12,0"/>
                                        <TextBlock Text="Presets" VerticalAlignment="Center" FontSize="13"/>
                                    </StackPanel>
                                </RadioButton>

                                <!-- Separator -->
                                <Border Height="1"
                                        Background="{StaticResource BorderSubtleBrush}"
                                        Margin="20,20"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Sidebar / content divider -->
                    <Border Grid.Column="1" Background="{StaticResource BorderSubtleBrush}"/>

                    <!-- ── CONTENT AREA ──────────────────────────────── -->
                    <Grid Grid.Column="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="340"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ── SETTINGS PANEL (left column) ────────── -->
                        <ScrollViewer Grid.Column="0"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="20,20,20,20">

                                <!-- ══════════════════════
                                     GENERATOR PANEL
                                ══════════════════════ -->
                                <StackPanel x:Name="GeneratorPanel" Visibility="Visible">

                                    <!-- ── Content Card ── -->
                                    <Border Background="{StaticResource Surface1Brush}"
                                            BorderBrush="{StaticResource BorderSubtleBrush}"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="18,16"
                                            Margin="0,0,0,12">
                                        <StackPanel>
                                            <!-- Section header -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                                <materialDesign:PackIcon Kind="Pencil"
                                                                         Width="14" Height="14"
                                                                         Foreground="{StaticResource AccentBrush}"
                                                                         VerticalAlignment="Center"
                                                                         Margin="0,0,8,0"/>
                                                <TextBlock Text="QR CONTENT"
                                                           Style="{StaticResource SectionLabelStyle}"
                                                           Margin="0"/>
                                            </StackPanel>

                                            <!-- Payload type tab control -->
                                            <TabControl x:Name="PayloadTabControl"
                                                        Style="{StaticResource PillTabControlStyle}"
                                                        SelectionChanged="SettingChanged">

                                                <!-- Tab: Text / URL -->
                                                <TabItem Header="Text / URL">
                                                    <StackPanel Margin="0,4,0,0">
                                                        <TextBlock Text="URL or Text Content"
                                                                   Style="{StaticResource FieldLabelStyle}"/>
                                                        <TextBox x:Name="DataTextBox"
                                                                 Style="{StaticResource ModernTextBoxStyle}"
                                                                 Background="{StaticResource Surface3Brush}"
                                                                 BorderBrush="#555555"
                                                                 BorderThickness="1"
                                                                 TextChanged="SettingChanged"/>
                                                    </StackPanel>
                                                </TabItem>

                                                <!-- Tab: Wi-Fi -->
                                                <TabItem Header="Wi-Fi">
                                                    <StackPanel Margin="0,4,0,0">
                                                        <TextBlock Text="Network Name (SSID)"
                                                                   Style="{StaticResource FieldLabelStyle}"/>
                                                        <TextBox x:Name="WifiSsidTextBox"
                                                                 Style="{StaticResource ModernTextBoxStyle}"
                                                                 Margin="0,0,0,12"
                                                                 TextChanged="SettingChanged"/>

                                                        <TextBlock Text="Password"
                                                                   Style="{StaticResource FieldLabelStyle}"/>
                                                        <PasswordBox x:Name="WifiPasswordBox"
                                                                     Style="{StaticResource ModernPasswordBoxStyle}"
                                                                     Margin="0,0,0,12"
                                                                     PasswordChanged="SettingChanged"/>

                                                        <TextBlock Text="Security Type"
                                                                   Style="{StaticResource FieldLabelStyle}"/>
                                                        <ComboBox x:Name="WifiAuthComboBox"
                                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                                  materialDesign:HintAssist.IsFloating="False"
                                                                  SelectedIndex="1"
                                                                  Margin="0,0,0,14"
                                                                  SelectionChanged="SettingChanged">
                                                            <ComboBoxItem Content="WEP"/>
                                                            <ComboBoxItem Content="WPA"/>
                                                            <ComboBoxItem Content="WPA2"/>
                                                            <ComboBoxItem Content="No Password"/>
                                                        </ComboBox>

                                                        <CheckBox x:Name="WifiHiddenCheckBox"
                                                                  Content="Hidden network"
                                                                  Style="{StaticResource ModernCheckBoxStyle}"
                                                                  Checked="SettingChanged"
                                                                  Unchecked="SettingChanged"/>
                                                    </StackPanel>
                                                </TabItem>

                                                <!-- Tab: vCard -->
                                                <TabItem Header="vCard">
                                                    <StackPanel Margin="0,4,0,0">
                                                        <TextBlock Text="Full Name"
                                                                   Style="{StaticResource FieldLabelStyle}"/>
                                                        <TextBox x:Name="VCardFullNameTextBox"
                                                                 Style="{StaticResource ModernTextBoxStyle}"
                                                                 Margin="0,0,0,12"
                                                                 TextChanged="SettingChanged"/>

                                                        <TextBlock Text="Phone"
                                                                   Style="{StaticResource FieldLabelStyle}"/>
                                                        <TextBox x:Name="VCardPhoneTextBox"
                                                                 Style="{StaticResource ModernTextBoxStyle}"
                                                                 Margin="0,0,0,12"
                                                                 TextChanged="SettingChanged"/>

                                                        <TextBlock Text="Email"
                                                                   Style="{StaticResource FieldLabelStyle}"/>
                                                        <TextBox x:Name="VCardEmailTextBox"
                                                                 Style="{StaticResource ModernTextBoxStyle}"
                                                                 Margin="0,0,0,12"
                                                                 TextChanged="SettingChanged"/>

                                                        <TextBlock Text="Company"
                                                                   Style="{StaticResource FieldLabelStyle}"/>
                                                        <TextBox x:Name="VCardCompanyTextBox"
                                                                 Style="{StaticResource ModernTextBoxStyle}"
                                                                 TextChanged="SettingChanged"/>
                                                    </StackPanel>
                                                </TabItem>
                                            </TabControl>
                                        </StackPanel>
                                    </Border>

                                    <!-- ── Logo Card ── -->
                                    <Border Background="{StaticResource Surface1Brush}"
                                            BorderBrush="{StaticResource BorderSubtleBrush}"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="18,16"
                                            Margin="0,0,0,12">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                                <materialDesign:PackIcon Kind="Image"
                                                                         Width="14" Height="14"
                                                                         Foreground="{StaticResource AccentBrush}"
                                                                         VerticalAlignment="Center"
                                                                         Margin="0,0,8,0"/>
                                                <TextBlock Text="LOGO"
                                                           Style="{StaticResource SectionLabelStyle}"
                                                           Margin="0"/>
                                            </StackPanel>

                                            <!-- Logo file picker -->
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="LogoPathTextBox"
                                                         Grid.Column="0"
                                                         Style="{StaticResource ModernTextBoxStyle}"
                                                         IsReadOnly="True"
                                                         TextChanged="SettingChanged"/>
                                                <Button x:Name="BrowseButton"
                                                        Grid.Column="1"
                                                        Style="{StaticResource GhostButtonStyle}"
                                                        Margin="8,0,0,0"
                                                        Click="BrowseButton_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon Kind="FolderOpen"
                                                                                 Width="14" Height="14"
                                                                                 VerticalAlignment="Center"
                                                                                 Margin="0,0,6,0"/>
                                                        <TextBlock Text="Browse" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                            </Grid>

                                            <!-- Logo size slider -->
                                            <TextBlock Text="Logo Size"
                                                       Style="{StaticResource FieldLabelStyle}"/>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Slider x:Name="LogoSizeSlider"
                                                        Grid.Column="0"
                                                        Minimum="10" Maximum="35" Value="15"
                                                        IsSnapToTickEnabled="True"
                                                        TickFrequency="1"
                                                        VerticalAlignment="Center"
                                                        Style="{StaticResource ModernSliderStyle}"
                                                        ValueChanged="SettingChanged"/>
                                                <Border Grid.Column="1"
                                                        Margin="10,0,0,0"
                                                        Background="{StaticResource AccentSubtleBrush}"
                                                        BorderBrush="{StaticResource AccentBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="8"
                                                        Padding="8,3"
                                                        MinWidth="46">
                                                    <TextBlock Text="{Binding Value, ElementName=LogoSizeSlider, StringFormat={}{0:0}%}"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Center"
                                                               Foreground="{StaticResource AccentBrush}"/>
                                                </Border>
                                            </Grid>

                                            <CheckBox x:Name="LogoBackgroundCheckBox"
                                                      Content="Add background padding behind logo"
                                                      Style="{StaticResource ModernCheckBoxStyle}"
                                                      IsChecked="True"
                                                      Checked="SettingChanged"
                                                      Unchecked="SettingChanged"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- ── Styling Card ── -->
                                    <Border Background="{StaticResource Surface1Brush}"
                                            BorderBrush="{StaticResource BorderSubtleBrush}"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="18,16"
                                            Margin="0,0,0,12">
                                        <StackPanel>
                                            <!-- Section header + reset button -->
                                            <Grid Margin="0,0,0,14">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="Palette"
                                                                             Width="14" Height="14"
                                                                             Foreground="{StaticResource AccentBrush}"
                                                                             VerticalAlignment="Center"
                                                                             Margin="0,0,8,0"/>
                                                    <TextBlock Text="STYLING"
                                                               Style="{StaticResource SectionLabelStyle}"
                                                               Margin="0"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <Button x:Name="ResetButton"
                                                        Grid.Column="1"
                                                        Height="28"
                                                        Padding="10,0"
                                                        FontSize="11"
                                                        Style="{StaticResource GhostButtonStyle}"
                                                        Click="ResetButton_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon Kind="Refresh"
                                                                                 Width="13" Height="13"
                                                                                 VerticalAlignment="Center"
                                                                                 Margin="0,0,5,0"/>
                                                        <TextBlock Text="Reset" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                            </Grid>

                                            <!-- Color rows -->
                                            <local:ColorRow x:Name="FgColorRow"
                                                            Label="Foreground"
                                                            InitialColor="#FF000000"
                                                            Margin="0,0,0,12"
                                                            ColorChanged="ColorRow_ColorChanged"/>

                                            <CheckBox x:Name="UseGradientCheckBox"
                                                      Content="Use Gradient"
                                                      Style="{StaticResource ModernCheckBoxStyle}"
                                                      Margin="0,0,0,12"
                                                      Checked="SettingChanged"
                                                      Unchecked="SettingChanged"/>

                                            <local:ColorRow x:Name="FgColor2Row"
                                                            Label="Foreground 2"
                                                            InitialColor="#FF3F51B5"
                                                            Margin="0,0,0,12"
                                                            Visibility="{Binding IsChecked, ElementName=UseGradientCheckBox, Converter={StaticResource BoolToVisibility}}"
                                                            ColorChanged="ColorRow_ColorChanged"/>

                                            <local:ColorRow x:Name="BgColorRow"
                                                            Label="Background"
                                                            InitialColor="#FFFFFFFF"
                                                            Margin="0,0,0,12"
                                                            ColorChanged="ColorRow_ColorChanged"/>

                                            <local:ColorRow x:Name="FinderColorRow"
                                                            Label="Finder Pattern"
                                                            InitialColor="#FF000000"
                                                            Margin="0,0,0,12"
                                                            ColorChanged="ColorRow_ColorChanged"/>

                                            <local:ColorRow x:Name="InnerEyeColorRow"
                                                            Label="Inner Eye"
                                                            InitialColor="#FF000000"
                                                            Margin="0,0,0,16"
                                                            ColorChanged="ColorRow_ColorChanged"/>

                                            <!-- Divider -->
                                            <Border Height="1"
                                                    Background="{StaticResource BorderSubtleBrush}"
                                                    Margin="0,0,0,14"/>

                                            <!-- Eye shape picker -->
                                            <TextBlock Text="Eye Shape"
                                                       Style="{StaticResource FieldLabelStyle}"/>
                                            <ComboBox x:Name="EyeShapeComboBox"
                                                      Style="{StaticResource ModernComboBoxStyle}"
                                                      materialDesign:HintAssist.IsFloating="False"
                                                      SelectedIndex="0"
                                                      Margin="0,0,0,12"
                                                      SelectionChanged="SettingChanged">
                                                <ComboBoxItem Content="Square"/>
                                                <ComboBoxItem Content="Rounded"/>
                                                <ComboBoxItem Content="Circular"/>
                                                <ComboBoxItem Content="Leaf"/>
                                                <ComboBoxItem Content="Shield"/>
                                            </ComboBox>

                                            <!-- Module shape picker -->
                                            <TextBlock Text="Module Shape"
                                                       Style="{StaticResource FieldLabelStyle}"/>
                                            <ComboBox x:Name="ShapeComboBox"
                                                      Style="{StaticResource ModernComboBoxStyle}"
                                                      materialDesign:HintAssist.IsFloating="False"
                                                      SelectedIndex="0"
                                                      SelectionChanged="SettingChanged">
                                                <ComboBoxItem Content="Squares"/>
                                                <ComboBoxItem Content="Rounded Squares"/>
                                                <ComboBoxItem Content="Dots / Circles"/>
                                                <ComboBoxItem Content="Liquid"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </Border>

                                </StackPanel><!-- /GeneratorPanel -->

                                <!-- ══════════════════════
                                     BATCH PANEL
                                ══════════════════════ -->
                                <StackPanel x:Name="BatchPanel" Visibility="Collapsed">

                                    <Border Background="{StaticResource Surface1Brush}"
                                            BorderBrush="{StaticResource BorderSubtleBrush}"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="18,16"
                                            Margin="0,0,0,12">
                                        <StackPanel>
                                            <!-- Section header -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                                <materialDesign:PackIcon Kind="FileMultiple"
                                                                         Width="14" Height="14"
                                                                         Foreground="{StaticResource AccentBrush}"
                                                                         VerticalAlignment="Center"
                                                                         Margin="0,0,8,0"/>
                                                <TextBlock Text="BATCH PROCESSING"
                                                           Style="{StaticResource SectionLabelStyle}"
                                                           Margin="0"/>
                                            </StackPanel>

                                            <!-- Info hint -->
                                            <Border Background="{StaticResource AccentSubtleBrush}"
                                                    BorderBrush="{StaticResource AccentBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="12,8"
                                                    Margin="0,0,0,16">
                                                <TextBlock Text="CSV format: data (required), filename (optional)"
                                                           FontSize="11"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           TextWrapping="Wrap"/>
                                            </Border>

                                            <!-- CSV file picker -->
                                            <TextBlock Text="CSV File"
                                                       Style="{StaticResource FieldLabelStyle}"/>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="BatchCsvPathTextBox"
                                                         Grid.Column="0"
                                                         Style="{StaticResource ModernTextBoxStyle}"
                                                         IsReadOnly="True"/>
                                                <Button x:Name="BatchBrowseCsvButton"
                                                        Grid.Column="1"
                                                        Style="{StaticResource GhostButtonStyle}"
                                                        Margin="8,0,0,0"
                                                        Click="BatchBrowseCsvButton_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon Kind="FolderOpen"
                                                                                 Width="14" Height="14"
                                                                                 VerticalAlignment="Center"
                                                                                 Margin="0,0,6,0"/>
                                                        <TextBlock Text="Browse" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                            </Grid>

                                            <!-- Output folder picker -->
                                            <TextBlock Text="Output Folder"
                                                       Style="{StaticResource FieldLabelStyle}"/>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="BatchOutputFolderTextBox"
                                                         Grid.Column="0"
                                                         Style="{StaticResource ModernTextBoxStyle}"
                                                         IsReadOnly="True"/>
                                                <Button x:Name="BatchBrowseOutputButton"
                                                        Grid.Column="1"
                                                        Style="{StaticResource GhostButtonStyle}"
                                                        Margin="8,0,0,0"
                                                        Click="BatchBrowseOutputButton_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon Kind="FolderOpen"
                                                                                 Width="14" Height="14"
                                                                                 VerticalAlignment="Center"
                                                                                 Margin="0,0,6,0"/>
                                                        <TextBlock Text="Browse" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                            </Grid>

                                            <!-- Output format -->
                                            <TextBlock Text="Output Format"
                                                       Style="{StaticResource FieldLabelStyle}"/>
                                            <ComboBox x:Name="BatchOutputFormatComboBox"
                                                      Style="{StaticResource ModernComboBoxStyle}"
                                                      materialDesign:HintAssist.IsFloating="False"
                                                      SelectedIndex="0"
                                                      Margin="0,0,0,16">
                                                <ComboBoxItem Content="PNG"/>
                                                <ComboBoxItem Content="SVG"/>
                                            </ComboBox>

                                            <!-- Divider -->
                                            <Border Height="1"
                                                    Background="{StaticResource BorderSubtleBrush}"
                                                    Margin="0,0,0,14"/>

                                            <!-- Progress -->
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Progress"
                                                           Style="{StaticResource FieldLabelStyle}"
                                                           Margin="0"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock x:Name="BatchStatusTextBlock"
                                                           Grid.Column="1"
                                                           Text="Idle"
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                            <ProgressBar x:Name="BatchProgressBar"
                                                         Style="{StaticResource ModernProgressBarStyle}"
                                                         Minimum="0" Maximum="100" Value="0"
                                                         Margin="0,0,0,16"/>

                                            <!-- Start / Cancel buttons -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="10"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Button x:Name="BatchStartButton"
                                                        Grid.Column="0"
                                                        Style="{StaticResource PrimaryButtonStyle}"
                                                        Click="BatchStartButton_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon Kind="Play"
                                                                                 Width="16" Height="16"
                                                                                 VerticalAlignment="Center"
                                                                                 Margin="0,0,8,0"/>
                                                        <TextBlock Text="Start Batch"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button x:Name="BatchCancelButton"
                                                        Grid.Column="2"
                                                        Style="{StaticResource OutlineButtonStyle}"
                                                        IsEnabled="False"
                                                        Click="BatchCancelButton_Click">
                                                    Cancel
                                                </Button>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                </StackPanel><!-- /BatchPanel -->

                                <!-- ══════════════════════
                                     PRESETS PANEL
                                ══════════════════════ -->
                                <StackPanel x:Name="PresetsPanel" Visibility="Collapsed">

                                    <Border Background="{StaticResource Surface1Brush}"
                                            BorderBrush="{StaticResource BorderSubtleBrush}"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="18,16"
                                            Margin="0,0,0,12">
                                        <StackPanel>
                                            <!-- Section header -->
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                                <materialDesign:PackIcon Kind="Star"
                                                                         Width="14" Height="14"
                                                                         Foreground="{StaticResource AccentBrush}"
                                                                         VerticalAlignment="Center"
                                                                         Margin="0,0,8,0"/>
                                                <TextBlock Text="STYLE PRESETS"
                                                           Style="{StaticResource SectionLabelStyle}"
                                                           Margin="0"/>
                                            </StackPanel>

                                            <TextBlock Text="Select a saved preset to apply all styling settings at once."
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,14"/>

                                            <TextBlock Text="Saved Presets"
                                                       Style="{StaticResource FieldLabelStyle}"/>
                                            <ComboBox x:Name="PresetComboBox"
                                                      Style="{StaticResource ModernComboBoxStyle}"
                                                      DisplayMemberPath="Name"
                                                      SelectionChanged="PresetComboBox_SelectionChanged"
                                                      Margin="0,0,0,16"/>

                                            <!-- Divider -->
                                            <Border Height="1"
                                                    Background="{StaticResource BorderSubtleBrush}"
                                                    Margin="0,0,0,14"/>

                                            <!-- Save / Load buttons -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="10"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Button x:Name="PresetSaveButton"
                                                        Grid.Column="0"
                                                        Style="{StaticResource PrimaryButtonStyle}"
                                                        Click="PresetSaveButton_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon Kind="ContentSave"
                                                                                 Width="16" Height="16"
                                                                                 VerticalAlignment="Center"
                                                                                 Margin="0,0,8,0"/>
                                                        <TextBlock Text="Save" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button x:Name="PresetLoadButton"
                                                        Grid.Column="2"
                                                        Style="{StaticResource OutlineButtonStyle}"
                                                        IsEnabled="False"
                                                        Click="PresetLoadButton_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon Kind="Download"
                                                                                 Width="16" Height="16"
                                                                                 VerticalAlignment="Center"
                                                                                 Margin="0,0,8,0"/>
                                                        <TextBlock Text="Load" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                </StackPanel><!-- /PresetsPanel -->

                            </StackPanel>
                        </ScrollViewer>

                        <!-- Settings / Preview divider -->
                        <Border Grid.Column="1" Background="{StaticResource BorderSubtleBrush}"/>

                        <!-- ── PREVIEW PANEL (right column) ─────────── -->
                        <Grid Grid.Column="2" Margin="24">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- QR Preview Card -->
                            <Border Grid.Row="0"
                                    Background="{StaticResource Surface1Brush}"
                                    BorderBrush="{StaticResource BorderSubtleBrush}"
                                    BorderThickness="1"
                                    CornerRadius="16"
                                    Margin="0,0,0,16"
                                    ClipToBounds="True">
                                <Grid>
                                    <!-- Empty state hint -->
                                    <Border x:Name="EmptyHint"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                        <Grid Width="260" Height="260">
                                            <Rectangle RadiusX="20" RadiusY="20"
                                                       Stroke="#2B3A52"
                                                       StrokeThickness="1.2"
                                                       StrokeDashArray="4 4"/>
                                            <StackPanel HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                <Border Width="56" Height="56" CornerRadius="14"
                                                        Background="{StaticResource Surface2Brush}"
                                                        BorderBrush="{StaticResource BorderSubtleBrush}"
                                                        BorderThickness="1"
                                                        Margin="0,0,0,12">
                                                    <materialDesign:PackIcon Kind="QrCode"
                                                                             Width="28" Height="28"
                                                                             HorizontalAlignment="Center"
                                                                             VerticalAlignment="Center"
                                                                             Foreground="{StaticResource TextSecondaryBrush}"/>
                                                </Border>
                                                <TextBlock Text="Enter content to generate"
                                                           FontSize="13"
                                                           Foreground="#C8D4E6"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="a QR code"
                                                           FontSize="13"
                                                           Foreground="#C8D4E6"
                                                           HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Live QR code image -->
                                    <Border x:Name="QrImageCard"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="{StaticResource SurfaceBrush}"
                                            BorderBrush="{StaticResource BorderSubtleBrush}"
                                            BorderThickness="1"
                                            CornerRadius="16"
                                            Padding="24"
                                            SnapsToDevicePixels="True">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ElementName=EmptyHint, Path=Visibility}" Value="Visible">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.Effect>
                                            <DropShadowEffect Color="#000000"
                                                              BlurRadius="24"
                                                              ShadowDepth="6"
                                                              Opacity="0.35"/>
                                        </Border.Effect>
                                        <Image x:Name="QrCodeImage"
                                               Stretch="Uniform"
                                               RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- Export action buttons -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        x:Name="SaveButton"
                                        Height="48"
                                        IsEnabled="False"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                    Background="{StaticResource AccentBrush}"
                                        Click="SaveButton_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ContentSave"
                                                                 Width="18" Height="18"
                                                                 VerticalAlignment="Center"
                                                                 Margin="0,0,10,0"/>
                                        <TextBlock Text="Save PNG"
                                                   FontSize="14"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Grid.Column="2"
                                        x:Name="ExportSvgButton"
                                        Height="48"
                                        IsEnabled="False"
                                        Style="{StaticResource OutlineButtonStyle}"
                                    Background="{StaticResource Surface3Brush}"
                                    BorderBrush="{StaticResource AccentHoverBrush}"
                                        Click="ExportSvgButton_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="FileCode"
                                                                 Width="18" Height="18"
                                                                 VerticalAlignment="Center"
                                                                 Margin="0,0,10,0"/>
                                        <TextBlock Text="Export SVG"
                                                   FontSize="14"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Grid>

                    </Grid><!-- /Content Grid -->
                </Grid><!-- /Row 1 Grid -->

            </Grid><!-- /Main Grid -->
        </materialDesign:DialogHost>
    </Border>
</Window>
